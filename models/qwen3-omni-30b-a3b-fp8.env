# =============================================================================
# Qwen3-Omni-30B-A3B-FP8  --  marksverdhei/Qwen3-Omni-30B-A3B-FP8
# =============================================================================
# FP8 MoE omni-modal model (30B total, 3B active). Understands text, image,
# audio, and video inputs. Text output only (Thinker path; no Talker/Code2Wav).
# Fits on a single H100 80GB (~35-37 GB FP8 weights).

MODEL_NAME="marksverdhei/Qwen3-Omni-30B-A3B-FP8"
NUM_GPUS=1

VLLM_ARGS="--tensor-parallel-size 1 \
    --max-model-len 12800 \
    --trust-remote-code \
    --gpu-memory-utilization 0.9 \
    --limit-mm-per-prompt image=3,video=1,audio=3 \
    --served-model-name qwen3-omni \
    --load-format auto"
