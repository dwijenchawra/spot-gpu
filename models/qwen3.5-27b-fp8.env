# =============================================================================
# Qwen3.5-27B-FP8 -- Qwen/Qwen3.5-27B-FP8
# =============================================================================
# Natively multimodal (vision + text + video). FP8 weights (~30 GB).
# Qwen3.5 architecture is not in stable vLLM yet — requires nightly in cu13/.venv.
# No --trust-remote-code needed.

MODEL_NAME="Qwen/Qwen3.5-27B-FP8"

# Use the CUDA-13 / vLLM-nightly venv
VENV_PROFILE="cu13/.venv"
REQUIRES_CUDA13="true"

# FP8 GEMM: flashinfer/cutlass, not deepgemm (known crash on Qwen3.5 FP8 MoE)
VLLM_USE_DEEP_GEMM="0"

# Native context is 262144; 131072 leaves ample room for KV cache on 4x H100-80GB.
# Vision is on by default — do NOT pass --language-model-only.
VLLM_ARGS="--tensor-parallel-size 4 \
    --max-model-len 64000 \
    --reasoning-parser qwen3 \
    --enable-auto-tool-choice \
    --tool-call-parser qwen3_coder \
    --gpu-memory-utilization 0.95 \
    --load-format fastsafetensors \
    --served-model-name qwen3.5-27b-fp8"
